# ─────────────────────────────────────────────────────────────────────────────
# IPAM Portal — Environment Variables
# Copy to .env and fill in all values before running setup.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MONGO_APP_USER=ipam_app
MONGO_APP_PASSWORD=CHANGE_ME_APP_PASSWORD
MONGODB_URI=mongodb://ipam_app:CHANGE_ME_APP_PASSWORD@mongodb:27017/ipam?authSource=ipam
MONGODB_DB_NAME=ipam

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_64_HEX_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_HOURS=8

# ── Initial Admin (remove BOTH lines after first login!) ─────────────────────
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
# For development, set to http://localhost:5173
ALLOWED_ORIGINS=https://ipam-portal.com
ENABLE_SWAGGER=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=200/minute
